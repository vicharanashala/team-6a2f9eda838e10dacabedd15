# =============================================
# Backend — Server
# =============================================
NODE_ENV=development
PORT=5000
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000

# =============================================
# Backend — MongoDB Atlas (cloud)
# =============================================
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<appName>

# =============================================
# Backend — Other Services
# =============================================
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200
KAFKA_BROKERS=localhost:9092

# =============================================
# Admin Seed Credentials (used by seeds/seed.js)
# =============================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=changeme123
ADMIN_DISPLAY_NAME=Admin

# =============================================
# Firebase Configuration (Frontend)
# =============================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# =============================================
# Frontend — API URLs
# =============================================
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
